#!/usr/bin/env python3
"""ltacproc – process LTAC assurance-case files and inject rendered views.

See docs/design-spec.md for the full specification.
"""

import argparse
import json
import os
import re
import sys
from dataclasses import dataclass
from typing import Dict, List, Optional, Set, Tuple

_had_error = False # If true, we saw an error during processing
_strict = False # If true, turn warnings into errors


def panic(msg: str) -> None:
    """Print a fatal error to stderr and exit immediately."""
    print(f"ltacproc: fatal: {msg}", file=sys.stderr)
    sys.exit(1)


def error(msg: str) -> None:
    """Print an error to stderr and set the error flag."""
    global _had_error
    print(f"ltacproc: error: {msg}", file=sys.stderr)
    _had_error = True


def warn(msg: str) -> None:
    """Print a warning to stderr; if --error is active, escalate to error()."""
    if _strict:
        error(msg)
    else:
        print(f"ltacproc: warning: {msg}", file=sys.stderr)


def notify(msg: str) -> None:
    """Print an informational notification to stderr."""
    print(f"ltacproc: {msg}", file=sys.stderr)


DEFAULT_CONFIG = {
    'base_url': '',
    'markdown_base_url': '',
}


def load_config(json_str: str) -> dict:
    """Load and validate configuration from a JSON string.

    If json_str is None, return a copy of DEFAULT_CONFIG.
    Unknown keys produce a warning; known keys are merged over the defaults.
    """
    if json_str is None:
        return dict(DEFAULT_CONFIG)
    try:
        parsed = json.loads(json_str)
    except json.JSONDecodeError as e:
        panic(f"invalid JSON in --config: {e}")
    for key in parsed:
        if key not in DEFAULT_CONFIG:
            warn(f"unknown config key: {key!r}")
    config = dict(DEFAULT_CONFIG)
    config.update({k: v for k, v in parsed.items() if k in DEFAULT_CONFIG})
    return config


# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------

def to_github_fragment(text: str) -> str:
    """Convert heading text to a GitHub anchor fragment id.

    Algorithm (matches GitHub's algorithm):
    1. Lowercase the entire string.
    2. Remove every character that is not a Unicode letter, digit,
       hyphen, or space.
    3. Replace spaces with hyphens.
    4. Collapse runs of multiple hyphens into a single hyphen.
    5. Strip leading and trailing hyphens.

    Example: "Package C1: Main Claim" -> "package-c1-main-claim"
    """
    text = text.lower()
    text = re.sub(r'[^\w\s-]', '', text)
    text = re.sub(r'\s+', '-', text)
    text = re.sub(r'-+', '-', text)
    return text.strip('-')


def make_diagram_id(identifier: str, counter: list) -> str:
    """Return a valid diagram node id for the given LTAC identifier.

    Used by all diagram renderers (SACM/mermaid, GSN/mermaid, etc.).
    Ids must match [A-Za-z0-9_]+.
    - Hyphens and dots become underscores.
    - Other non-alphanumeric characters are removed.
    - If identifier is empty, generate '_auto{N}' using counter[0]++.
    - Prefix with underscore if the first character is a digit.
    """
    if not identifier:
        idx = counter[0]
        counter[0] += 1
        return f'_auto{idx}'
    result = re.sub(r'[-.]', '_', identifier)
    result = re.sub(r'[^A-Za-z0-9_]', '', result)
    if not result:
        idx = counter[0]
        counter[0] += 1
        return f'_auto{idx}'
    if result[0].isdigit():
        result = '_' + result
    return result


def escape_html(text: str) -> str:
    """Escape text for safe embedding in mermaid HTML labels.

    Replaces & -> &amp;  < -> &lt;  > -> &gt;  " -> &quot;
    """
    text = text.replace('&', '&amp;')
    text = text.replace('<', '&lt;')
    text = text.replace('>', '&gt;')
    text = text.replace('"', '&quot;')
    return text


def parse_options(raw: str) -> set:
    """Parse a {OPTIONS} suffix string into a set of option names.

    raw is the content between { and } (already stripped of braces).
    Splits on commas, strips whitespace, lowercases each token.
    Returns a set of lowercase strings.
    """
    if not raw.strip():
        return set()
    return {token.strip().lower() for token in raw.split(',') if token.strip()}


# ---------------------------------------------------------------------------
# Data model
# ---------------------------------------------------------------------------

@dataclass
class Node:
    node_type: str           # Claim|Strategy|Justification|Evidence|
                             # Context|Assumption|Link|Relation|Connector
    identifier: str          # e.g. "C1"; empty string if absent
    text: str                # descriptive text (statement / reasoning)
    ext_ref: str             # text from trailing (...), empty if absent
    options: Set[str]        # e.g.: needsSupport axiomatic defeated
                             #        counter abstract assumed
    children: List['Node']   # child nodes
    is_cited: bool           # True when identifier had a ^ prefix
    cited_pkg: str           # package name from ^[PkgName] prefix; '' = default
    depth: int               # 0-based indentation level (0 = root)
    parent: Optional['Node'] # back-reference; None for roots
    link_target: Optional['Node']  # for Link nodes: referenced node
    diagram_id: str          # computed valid diagram node id for any renderer


# ---------------------------------------------------------------------------
# LTAC parser
# ---------------------------------------------------------------------------

# This parses an LTAC line with a regex, and pulls out relevant pieces.
# Compiled regexes perform well in Python.
_LTAC_LINE_RE = re.compile(
    r'^(?P<indent>(?:  )*)'
    r'[-*] '
    r'(?P<nodetype>Claim|Strategy|Evidence|Justification'
    r'|Context|Assumption|Relation|Link)'
    r'(?:\s+(?P<cited>\^)?(?:\[(?P<cited_pkg>[^\]]*)\])?(?P<identifier>[^:{\n(]*))?'
    r'(?::\s*(?P<text>[^({]*))?'
    r'(?:\s*\((?P<ref>[^)\n]*)\))?'
    r'(?:\s*\{(?P<options>[^}\n]*)\})?'
    r'\s*$'
)


class LTACParser:
    def parse(self, lines: List[str]) -> List[Node]:
        """Parse LTAC lines into a forest (list of root Nodes).

        Returns one root Node per package.
        Also populates self.registry: Dict[str, Node] mapping each
        identifier to its Node (for Link resolution).
        """
        self.registry: Dict[str, Node] = {}
        self.results: List[Node] = []
        self.node_count: int = 0
        self._stack: List[Tuple[int, Node]] = []
        self._current_pkg: List[Node] = []
        self._pkg_root_lineno: Optional[int] = None
        self._id_counter: List[int] = [0]
        self._links: List[Tuple[Node, int]] = []

        for lineno, line in enumerate(lines, 1):
            self._parse_line(lineno, line)

        # Finalize last open package
        if self._stack or self._current_pkg:
            self._finalize_package()

        # Resolve Link targets (done after full parse so forward refs work)
        for node, lineno in self._links:
            self._resolve_link(node, lineno)

        return self.results

    def _parse_line(self, lineno: int, line: str) -> None:
        """Process a single LTAC source line, updating parser state."""
        stripped = line.strip()
        if not stripped or stripped.startswith('//'):
            if self._stack or self._current_pkg:
                self._finalize_package()
            return

        m = _LTAC_LINE_RE.match(line)
        if not m:
            error(f"line {lineno}: unrecognized syntax: {line.rstrip()!r}")
            return

        node = self._build_node(m, lineno)
        self._attach_node(node, lineno)

    def _build_node(self, m, lineno: int) -> Node:
        """Construct a Node from a successful regex match."""
        depth = len(m.group('indent')) // 2
        nodetype = m.group('nodetype')
        is_cited = bool(m.group('cited'))
        cited_pkg = (m.group('cited_pkg') or '').strip()
        identifier = (m.group('identifier') or '').strip()
        text = (m.group('text') or '').strip()
        ref = (m.group('ref') or '').strip()
        options = parse_options(m.group('options') or '')

        diagram_id = make_diagram_id(identifier, self._id_counter)

        node = Node(
            node_type=nodetype,
            identifier=identifier,
            text=text,
            ext_ref=ref,
            options=options,
            children=[],
            is_cited=is_cited,
            cited_pkg=cited_pkg,
            depth=depth,
            parent=None,
            link_target=None,
            diagram_id=diagram_id,
        )
        self.node_count += 1
        return node

    def _attach_node(self, node: Node, lineno: int) -> None:
        """Register the node's identifier, attach it to the tree, and push it onto the stack."""
        if node.node_type == 'Link':
            self._links.append((node, lineno))
        elif node.identifier:
            if node.identifier in self.registry:
                warn(f"line {lineno}: duplicate identifier {node.identifier!r}")
            else:
                self.registry[node.identifier] = node

        # Pop stack until top's depth < current depth
        while self._stack and self._stack[-1][0] >= node.depth:
            self._stack.pop()

        if self._stack:
            parent_node = self._stack[-1][1]
            node.parent = parent_node
            parent_node.children.append(node)
        else:
            if self._current_pkg:
                panic(
                    f"package starting at line {self._pkg_root_lineno} "
                    f"already has a top-level element; only one allowed"
                )
            self._current_pkg.append(node)
            self._pkg_root_lineno = lineno

        self._stack.append((node.depth, node))

    def _resolve_link(self, node: Node, lineno: int) -> None:
        """Set link_target on a Link node, warning if the target is unknown."""
        target_id = node.identifier
        if target_id in self.registry:
            node.link_target = self.registry[target_id]
        else:
            warn(f"line {lineno}: Link target {target_id!r} not found")

    def _finalize_package(self) -> None:
        """Flush the current package's root into results and reset package state."""
        self.results.extend(self._current_pkg)
        self._current_pkg = []
        self._pkg_root_lineno = None
        self._stack = []


def parse_ltac_lines(lines: List[str]) -> Tuple[List[Node], Dict[str, Node]]:
    """Parse LTAC lines and return (roots, registry)."""
    parser = LTACParser()
    roots = parser.parse(lines)
    return roots, parser.registry


def _count_all_nodes(roots: List[Node]) -> int:
    """Count all nodes in the forest by tree traversal."""
    total = 0
    stack = list(roots)
    while stack:
        node = stack.pop()
        total += 1
        stack.extend(node.children)
    return total


# ---------------------------------------------------------------------------
# LTAC file loader
# ---------------------------------------------------------------------------

def load_ltac_file(path: str, all_roots: List[Node], registry: Dict[str, Node]) -> None:
    """Parse an LTAC file and merge its roots and registry into the given collections."""
    try:
        with open(path) as f:
            lines = f.readlines()
    except OSError as e:
        panic(f"cannot open {path!r}: {e}")
    roots, new_registry = parse_ltac_lines(lines)
    all_roots.extend(roots)
    for ident, node in new_registry.items():
        if ident in registry:
            warn(f"{path}: duplicate identifier {ident!r} (already seen in a previous file)")
        else:
            registry[ident] = node


# ---------------------------------------------------------------------------
# CLI helpers
# ---------------------------------------------------------------------------

def parse_args() -> argparse.Namespace:
    """Build the argument parser, define all flags, and parse the command line."""
    parser = argparse.ArgumentParser(
        prog='ltacproc',
        description='Process LTAC assurance-case files and inject rendered'
                    ' views into Markdown/HTML documents.',
        epilog='For full details see docs/design-spec.md.',
    )
    parser.add_argument(
        '--config', type=str, metavar='JSON',
        help='configure the tool with a JSON object',
    )
    parser.add_argument(
        '--error', action='store_true',
        help='treat warnings as errors (non-zero exit on any warning)',
    )
    parser.add_argument(
        '--ltac', '-l', type=str, metavar='FILENAME',
        help='LTAC file to load (default: case.ltac or docs/case.ltac)',
    )
    parser.add_argument(
        'files', nargs='*',
        help='Markdown/HTML files to process (default: stdin)',
    )

    mode = parser.add_mutually_exclusive_group()
    mode.add_argument(
        '--validate', action='store_true',
        help='validate and report warnings/errors; do not produce output',
    )
    mode.add_argument(
        '--select', '-s', type=str, metavar='SELECTOR',
        help='print the selected SELECTOR output to stdout and exit',
    )
    mode.add_argument(
        '--inline', '-i', action='store_true',
        help='rewrite each file in place with updated marked regions',
    )

    return parser.parse_args()


def find_ltac_file(ltac_arg: Optional[str]) -> str:
    """Determine the path of the LTAC file to load.

    If --ltac was given, use that path directly.
    Otherwise try case.ltac in the current directory, then docs/case.ltac.
    Calls panic() (and exits) if no file can be found.
    """
    if ltac_arg:
        return ltac_arg
    if os.path.exists('case.ltac'):
        return 'case.ltac'
    if os.path.exists('docs/case.ltac'):
        return 'docs/case.ltac'
    panic("no LTAC file found; use --ltac or create case.ltac")


def check_cited_packages(all_roots: List[Node], registry: Dict[str, Node]) -> None:
    """Warn about any external ^[PkgName] citations that could not be resolved."""
    pkg_names = {'Package ' + root.identifier for root in all_roots if root.identifier}
    for node in registry.values():
        if node.is_cited and node.cited_pkg and node.cited_pkg not in pkg_names:
            warn(f"cited package {node.cited_pkg!r} not found in loaded LTAC")


def main() -> None:
    """Entry point: parse arguments, load configuration and LTAC data, then dispatch."""
    global _strict

    args = parse_args()

    if args.error:
        _strict = True

    config = load_config(args.config)
    notify(f"config: {config}")

    all_roots: List[Node] = []
    registry: Dict[str, Node] = {}

    ltac_path = find_ltac_file(args.ltac)
    load_ltac_file(ltac_path, all_roots, registry)
    notify(f"Loaded {len(all_roots)} package(s), {_count_all_nodes(all_roots)} node(s)")

    check_cited_packages(all_roots, registry)

    if _had_error:
        sys.exit(1)


if __name__ == '__main__':
    main()
